{
  "name": "starshelf",
  "description": "Auto-categorize GitHub starred repos with AI",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:nobrowser": "VITE_BROWSER_DISABLED=true wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "zip:all": "wxt zip && wxt zip -b firefox",
    "check": "bun run format:check && bun run compile && bun run test",
    "format": "bunx prettier --write '**/*.{ts,css,html}'",
    "format:check": "bunx prettier --check '**/*.{ts,css,html}'",
    "test": "vitest run",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare",
    "submit": "wxt submit --chrome-zip dist/*-chrome.zip --firefox-zip dist/*-firefox.zip --firefox-sources-zip dist/*-sources.zip",
    "submit:dry-run": "rm -rf dist/*.zip && bun run zip:all && bun run submit --dry-run",
    "submit:hot": "rm -rf dist/*.zip && bun run zip:all && bun run submit"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.1.7",
    "wxt": "^0.20.26"
  },
  "dependencies": {
    "fuse.js": "^7.4.2"
  }
}
