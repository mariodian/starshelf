VITE_ANTHROPIC_MODEL=

VITE_OPENAI_API_KEY=
VITE_OPENAI_MODEL=

VITE_OPENCODE_API_KEY=
VITE_OPENCODE_MODEL=
VITE_OPENCODE_ENDPOINT=zen
